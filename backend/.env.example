# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# --- Required ---
OPENAI_API_KEY=sk-...          # Your OpenAI API key

# --- Database ---
# Local development (DEBUG=True): uses SQLite — set DATABASE_URL below
# Production (DEBUG=False): builds PostgreSQL URL from DB_* vars below
DATABASE_URL=sqlite:///./database.db

# Production PostgreSQL (only needed when DEBUG=False)
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=5432
# DB_NAME=

# --- App settings ---
API_PREFIX=/api
DEBUG=True                     # True = SQLite, False = PostgreSQL

# Comma-separated list of allowed CORS origins
# Local dev: include your Vite dev server port
# Production: set to your deployed frontend URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
