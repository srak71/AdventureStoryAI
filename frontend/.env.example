# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored so secrets stay off of version control.

# Set to "true" to enable the Vite dev-server proxy that forwards
# /api requests to the local FastAPI backend (http://localhost:8000).
# Leave unset or set to "false" in production.
VITE_DEBUG=true

# Override the API base URL when deploying to a custom domain.
# If omitted, the app defaults to "/api" (local proxy) or the
# platform-specific path set in util.js.
# VITE_API_BASE_URL=https://your-api-domain.com/api
